import json

with open("channels.json", "r", encoding="utf-8") as f:
    channels = json.load(f)

logos = []

for ch in channels:
    cid = ch.get("id")
    name = ch.get("name")
    logo = ch.get("logo")

    if not cid or not logo:
        continue

    logos.append({
        "id": cid,
        "name": name,
        "logo": logo
    })

with open("logos.json", "w", encoding="utf-8") as f:
    json.dump(logos, f, ensure_ascii=False, indent=2)

print(f"SUCCESS: logos.json generated for {len(logos)} channels")
